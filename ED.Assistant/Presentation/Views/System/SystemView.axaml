<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ED.Assistant.Presentation.ViewModels.System"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:DataType="vm:SystemViewModel"
			 x:Class="ED.Assistant.Presentation.Views.System.SystemView">
	<Grid ColumnSpacing="16">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="2*" MinWidth="380"/>
			<ColumnDefinition Width="3*" MinWidth="420"/>
		</Grid.ColumnDefinitions>

		<Border Classes="dashboard-card">
			<Grid RowSpacing="12">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<TextBlock Text="SYSTEM STRUCTURE"
						   Classes="dashboard-card-header"/>

				<ScrollViewer Grid.Row="1">
					<TreeView Classes="system-tree"
							  ItemsSource="{Binding Bodies}"
							  SelectedItem="{Binding SelectedBody, Mode=TwoWay}">
						<TreeView.ItemTemplate>
							<TreeDataTemplate ItemsSource="{Binding Children}">
								<StackPanel Orientation="Horizontal"
											Spacing="8"
											Margin="4,2">
									<TextBlock Text="{Binding Type}"
											   Classes="dashboard-label"/>
									<TextBlock Text="{Binding Name}"
											   Classes="dashboard-value"/>
								</StackPanel>
							</TreeDataTemplate>
						</TreeView.ItemTemplate>
					</TreeView>
				</ScrollViewer>
			</Grid>
		</Border>

		<Border Grid.Column="1"
				Classes="dashboard-card">
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel Spacing="12">
					<TextBlock Text="BODY DETAILS"
							   Classes="dashboard-card-header"/>
					<TextBlock Text="{Binding SelectedBody.Name}"
							   Classes="dashboard-system-name"/>
					<TextBlock Text="{Binding SelectedBody.Type}"
							   Classes="dashboard-label"/>

					<Grid RowSpacing="6"
						  ColumnSpacing="12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="160"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Text="Scan type"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Column="1"
								   Text="{Binding SelectedBody.Scan.ScanType}"
								   Foreground="{Binding SelectedBody.Scan.ScanType,
								   Converter={StaticResource ScanTypeForegroundConverter}}"
								   Classes="dashboard-value"/>

						<TextBlock Grid.Row="1"
								   Text="Distance"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Row="1"
								   Grid.Column="1"
								   Text="{Binding SelectedBody.DistanceLs}"
								   Classes="dashboard-value"/>

						<TextBlock Grid.Row="2"
								   Text="Radius"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Row="2"
								   Grid.Column="1"
								   Text="{Binding SelectedBody.RadiusKm}"
								   Classes="dashboard-value"/>

						<TextBlock Grid.Row="3"
								   Text="Temperature"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Row="3"
								   Grid.Column="1"
								   Text="{Binding SelectedBody.SurfaceTemperatureK}"
								   Classes="dashboard-value"/>
					</Grid>

					<Border Classes="dashboard-card"
							IsVisible="{Binding SelectedBody.IsStar}">
						<Grid RowSpacing="6"
							  ColumnSpacing="12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="160"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<TextBlock Text="Star type"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.StarType}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="1"
									   Text="Mass"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="1"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Mass}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="2"
									   Text="Luminosity"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="2"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.Luminosity}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="3"
									   Text="Age"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="3"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.Age}"
									   Classes="dashboard-value"/>
						</Grid>
					</Border>

					<Border Classes="dashboard-card"
							IsVisible="{Binding SelectedBody.IsPlanet}">
						<Grid RowSpacing="6"
							  ColumnSpacing="12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="160"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<TextBlock Text="Planet class"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.PlanetClass}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="1"
									   Text="Mass"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="1"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Mass}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="2"
									   Text="Gravity"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="2"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Gravity}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="3"
									   Text="Atmosphere"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="3"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.Atmosphere}"
									   TextWrapping="Wrap"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="4"
									   Text="Terraform"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="4"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.TerraformState}"
									   Classes="dashboard-value"/>

							<TextBlock Grid.Row="5"
									   Text="Landable"
									   Classes="dashboard-label"/>
							<TextBlock Grid.Row="5"
									   Grid.Column="1"
									   Text="{Binding SelectedBody.Scan.IsLandable}"
									   Classes="dashboard-value"/>
						</Grid>
					</Border>

					<Grid RowSpacing="6"
						  ColumnSpacing="12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="160"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Text="Discovered"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Column="1"
								   Text="{Binding SelectedBody.Scan.WasDiscovered}"
								   Classes="dashboard-value"/>

						<TextBlock Grid.Row="1"
								   Text="Mapped"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Row="1"
								   Grid.Column="1"
								   Text="{Binding SelectedBody.Scan.WasMapped}"
								   Classes="dashboard-value"/>

						<TextBlock Grid.Row="2"
								   Text="Footfall"
								   Classes="dashboard-label"/>
						<TextBlock Grid.Row="2"
								   Grid.Column="1"
								   Text="{Binding SelectedBody.Scan.WasFootfalled}"
								   Classes="dashboard-value"/>
					</Grid>

					<Border Classes="dashboard-card"
							Padding="12"
							Margin="0,8,0,0">
						<StackPanel Spacing="10">
							<Grid ColumnDefinitions="*,Auto">
								<TextBlock Text="SIGNALS"
										   Classes="dashboard-card-header"/>

								<TextBlock Grid.Column="1"
										   Text="{Binding SelectedBody.SignalsTotalCount}"
										   Classes="dashboard-value"/>
							</Grid>

							<ItemsControl ItemsSource="{Binding SelectedBody.Signals}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border Classes="signal-row">
											<Grid ColumnSpacing="10">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto"/>
													<ColumnDefinition Width="*"/>
													<ColumnDefinition Width="Auto"/>
												</Grid.ColumnDefinitions>

												<Border Classes="signal-dot"
														Tag="{Binding Type}"/>

												<TextBlock Grid.Column="1"
														   Text="{Binding Name}"
														   Classes="dashboard-value"/>

												<TextBlock Grid.Column="2"
														   Text="{Binding Count}"
														   Classes="dashboard-value"
														   VerticalAlignment="Center"/>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<TextBlock Text="No signals detected"
									   Classes="dashboard-label"
									   IsVisible="{Binding !SelectedBody.HasSignals}"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>
