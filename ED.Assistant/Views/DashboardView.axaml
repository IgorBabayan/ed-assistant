<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:ED.Assistant.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ED.Assistant.DashboardView"
			 x:DataType="vm:DashboardViewModel"
			 Margin="{DynamicResource Margin15}">
	<Grid RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="2*,*"
          Margin="20"
          RowSpacing="16"
          ColumnSpacing="16">

        <!-- Current System -->
        <!--<Border Grid.Row="0"
                Grid.Column="0"
                Classes="dashboard-card">
            <StackPanel Spacing="10">
                <TextBlock Text="CURRENT SYSTEM"
                           Classes="dashboard-card-header"/>

                <TextBlock Text="{Binding CurrentSystem.Name}"
                           Classes="dashboard-system-name"/>

                <UniformGrid Columns="2"
                             Rows="2">
                    <StackPanel>
                        <TextBlock Text="Star Type" Classes="dashboard-label"/>
                        <TextBlock Text="{Binding CurrentSystem.StarType}" Classes="dashboard-value"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Security" Classes="dashboard-label"/>
                        <TextBlock Text="{Binding CurrentSystem.Security}" Classes="dashboard-value"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Economy" Classes="dashboard-label"/>
                        <TextBlock Text="{Binding CurrentSystem.Economy}" Classes="dashboard-value"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Population" Classes="dashboard-label"/>
                        <TextBlock Text="{Binding CurrentSystem.Population}" Classes="dashboard-value"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>-->

        <!-- CMDR Profile -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Classes="dashboard-card">
            <StackPanel Spacing="12">
                <TextBlock Text="CMDR PROFILE"
                           Classes="dashboard-card-header"/>

                <TextBlock Text="{Binding Commander.Name}"
                           Classes="dashboard-commander-name"/>

                <TextBlock Text="{Binding LoadGame.ShipFullTitle}"
                           Classes="dashboard-value"/>

                <Separator/>

                <ItemsControl ItemsSource="{Binding Ranks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="90,*,80"
                                  Margin="0,4">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           Classes="dashboard-label"/>

                                <ProgressBar Grid.Column="1"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding Progress}"
                                             Height="6"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Level}"
                                           Classes="dashboard-rank"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Signals -->
        <!--<Border Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Classes="dashboard-card">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">

                <DockPanel>
                    <TextBlock Text="SIGNALS"
                               Classes="dashboard-card-header"
                               DockPanel.Dock="Left"/>

                    <TextBlock Text="{Binding Signals.Count, StringFormat='{}{0} detected'}"
                               Classes="dashboard-label"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Signals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="signal-row">
                                    <Grid ColumnDefinitions="120,*,120,100"
                                          ColumnSpacing="12">

                                        <Border Grid.Column="0"
                                                Classes="signal-badge">
                                            <TextBlock Text="{Binding Type}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Classes="signal-title"/>
                                            <TextBlock Text="{Binding BodyName}"
                                                       Classes="dashboard-label"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Distance}"
                                                   Classes="dashboard-value"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding ThreatLevel, StringFormat='Threat {0}'}"
                                                   Classes="dashboard-rank"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>-->

        <!-- Recent Events -->
        <!--<Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Classes="dashboard-card">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="8">

                <TextBlock Text="RECENT EVENTS"
                           Classes="dashboard-card-header"/>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding RecentEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="80,*"
                                  Margin="0,3">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Time}"
                                           Classes="dashboard-label"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Message}"
                                           Classes="dashboard-value"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>-->

    </Grid>
</UserControl>
