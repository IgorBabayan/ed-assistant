<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="ED.Assistant.App"
			 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 xmlns:views="using:ED.Assistant"
			 xmlns:vm="using:ED.Assistant.ViewModels"
			 RequestedThemeVariant="Default">
	<!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://ED.Assistant/Styles/Theme.axaml" />
		</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>

	<Application.Styles>
		<FluentTheme />
		<materialIcons:MaterialIconStyles />
		<StyleInclude Source="avares://ED.Assistant/Styles/TextBlock.axaml" />
		<StyleInclude Source="avares://ED.Assistant/Styles/Button.axaml" />
		<StyleInclude Source="avares://ED.Assistant/Styles/Border.axaml" />
		<StyleInclude Source="avares://ED.Assistant/Styles/TreeView.axaml" />
	</Application.Styles>

	<Application.DataTemplates>
		<DataTemplate DataType="{x:Type vm:DashboardViewModel}">
			<views:DashboardView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:SystemViewModel}">
			<views:SystemView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:BodiesViewModel}">
			<views:BodiesView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:SignalsViewModel}">
			<views:SignalsView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:JournalViewModel}">
			<views:JournalView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:MaterialViewModel}">
			<views:MaterialView />
		</DataTemplate>
	</Application.DataTemplates>
</Application>